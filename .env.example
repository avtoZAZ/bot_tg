# .env.example - Приклад файлу конфігурації
# Скопіюйте цей файл як .env та заповніть власними значеннями

# ==================== ОСНОВНІ НАЛАШТУВАННЯ ====================
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_ID=1234567890

# ==================== БАЗА ДАНИХ ====================
DATABASE_URL=sqlite+aiosqlite:///bot_data.db

# ==================== БЕЗПЕКА ====================
MAX_REQUESTS_PER_MINUTE=30
MAX_FAILED_ATTEMPTS=5
BLOCK_TIME=3600
BLOCKED_USERS=
ALLOWED_DOMAINS=t.me,telegram.me,telegra.ph
LOG_SENSITIVE_DATA=False
ADMIN_WHITELIST_ENABLED=False
ADMIN_WHITELIST=
VALIDATE_AD_URLS=True

# ==================== РЕКЛАМА ====================
ADS_ENABLED=True
AD_FREQUENCY=3
ADS_ONLY_FREE_USERS=True

# ==================== КЕШУВАННЯ ====================
CACHE_ENABLED=True
VIDEO_CACHE_SIZE=200
VIDEO_CACHE_TTL=300
RECOMMENDATIONS_CACHE_SIZE=100
RECOMMENDATIONS_CACHE_TTL=600

# ==================== РЕКОМЕНДАЦІЇ ====================
RECOMMENDATIONS_ENABLED=True
RECOMMENDATIONS_LIMIT=5
TOP_WEEKLY_LIMIT=5

# ==================== РЕФЕРАЛЬНА СИСТЕМА ====================
REFERRAL_ENABLED=True
REFERRAL_BONUS_DAYS=3
REFERRAL_PAYMENT_BONUS_DAYS=7

# ==================== РОЗСИЛКА ====================
BROADCAST_DELAY=0.05
BROADCAST_CHUNK_SIZE=20
BROADCAST_CHUNK_DELAY=1.0

# ==================== ПРОМОКОДИ ====================
PROMO_CODES_ENABLED=True

# ==================== ПІДПИСКИ НА СЕРІАЛИ ====================
SERIES_NOTIFICATIONS_ENABLED=True

# ==================== РЕЙТИНГИ ====================
RATINGS_ENABLED=True
MIN_RATINGS_FOR_DISPLAY=3

# ==================== АНАЛІТИКА ====================
ANALYTICS_ENABLED=True
SAVE_SEARCH_QUERIES=True
TRACK_AD_CLICKS=True
